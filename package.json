  "license": "ISC",
  "author": "ra",
  "type": "module",
  "scripts": {
    "build": "tsc && vite build && vite build -c vite.config.blocks.ts",
    "build:blocks": "vite build -c vite.config.blocks.ts",
    "dev:blocks": "vite build -c vite.config.blocks.ts --watch",
    "clean": "rm -rf node_modules",
    "db:push": "drizzle-kit push",
    "db:seed": "tsx backend/db/seed.ts",
    "db:studio": "drizzle-kit studio",
    "dev": "vite",
    "env:clean": "wp-env clean",
    "env:destroy": "wp-env destroy",
    "env:logs": "wp-env logs",
    "env:shell": "wp-env run wordpress bash",
    "preenv:start": "composer install --no-dev",
    "env:start": "wp-env start",
    "env:stop": "wp-env stop",
    "env:wp": "wp-env run wordpress wp",
    "lint": "eslint frontend --fix ;composer lint; oxfmt frontend",
    "lint:php": "composer lint",
    "format": "oxfmt ./frontend/src",
    "format:dry": "oxfmt ./frontend/src --check",
    "preview": "vite preview",
    "prod": "vite build && vite build -c vite.config.blocks.ts",
    "prod:zip": "node bin/prod-zip.mjs",
    "production": "composer install --no-dev && pnpm install && pnpm i18n && pnpm build",
    "reset": "pnpm clean && pnpm install",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test": "vitest --watch=false -c ./vite.config.ts",
    "test:cover": "vitest --coverage",
    "test:e2e": "playwright test",
    "test:watch": "vitest --watch=true --ui=false",
    "ts-check": "tsc",
    "type-cov": "pnpx type-coverage -p ./tsconfig.json --strict --details",
    "update-ver": "node scripts/update-version.js",
    "wp-cli": "wp-env run cli wp",
    "plugin-check": "wp-env run cli wp plugin check /var/www/html/wp-content/plugins/icon-base/build/icon-base"
  },
