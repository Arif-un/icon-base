{
  "name": "arif-un/icon-base",
  "description": "Add 4,500+ self-hosted SVG icons to WordPress with instant full-text search and a Gutenberg icon block.",
  "type": "wordpress-plugin",
  "license": "GPL-2.0-or-later",
  "require": {
    "php": ">=7.4",
    "bitapps/wp-validator": "^1",
    "bitapps/wp-kit": "^2.0",
    "typisttech/imposter-plugin": "^0.6.2"
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3",
    "symfony/console": "^5.4 || ^6.0 || ^7.0",
    "squizlabs/php_codesniffer": "^3.13",
    "phpcompatibility/phpcompatibility-wp": "^2.1",
    "wp-coding-standards/wpcs": "^3.3",
    "sirbrillig/phpcs-variable-analysis": "^2.13",
    "slevomat/coding-standard": "^8.22",
    "pestphp/pest": "^4.7",
    "brain/monkey": "^2.7"
  },
  "autoload": {
    "psr-4": {
      "IconBase\\": "./backend/app",
      "IconBase\\DB\\": "./backend/db"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "IconBase\\CLI\\": "./cli",
      "Tests\\": "./tests"
    }
  },
  "scripts": {
    "clean": "rm -rf ./vendor && rm composer.lock && rm -rf ./dependencies",
    "reset": "composer clean && composer install",
    "phpcs": "phpcs -s",
    "lint": "./vendor/bin/php-cs-fixer fix --config=.php-cs-fixer.php && composer phpcs",
    "phpcs:fix": "phpcbf",
    "phpcs:report": "phpcs --report=summary --runtime-set ignore_errors_on_exit 1 --runtime-set ignore_warnings_on_exit 1",
    "test": "./vendor/bin/pest",
    "test:unit": "./vendor/bin/pest --testsuite=Unit",
    "test:integration": "./vendor/bin/pest --testsuite=Integration",
    "test:coverage": "./vendor/bin/pest --coverage"
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true,
      "typisttech/imposter-plugin": true,
      "pestphp/pest-plugin": true
    }
  },
  "extra": {
    "imposter": {
      "namespace": "IconBase\\Deps\\"
    }
  }
}