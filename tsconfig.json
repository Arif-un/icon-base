{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "moduleResolution": "bundler",
    /* Strictness */
    "strict": true,
    "strictNullChecks": true,
    "noUnusedParameters": true,
    "noUnusedLocals": true,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,
    "verbatimModuleSyntax": true,
    /* Module */
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "allowJs": true,
    /* Emit */
    "noEmit": true,
    "useDefineForClassFields": true,
    "skipLibCheck": true,
    /* JSX */
    "jsx": "react-jsx",
    /* Types */
    "types": [
      "node",
      "vite/client"
    ],
    "typeRoots": [
      "./frontend/src/types",
      "./node_modules/@types"
    ],
    /* Plugins */
    "plugins": [
      {
        "name": "typescript-plugin-css-modules"
      }
    ],
    /* Paths */
    "paths": {
      "@/*": [
        "./frontend/src/*"
      ],
    }
  },
  "include": [
    "./frontend",
    "./frontend/src/types",
    "./scripts",
    "./.storybook"
  ],
  "exclude": [
    "node_modules"
  ]
}