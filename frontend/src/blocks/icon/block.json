{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "icon-base/icon",
  "version": "2.0.0",
  "title": "Icon Base",
  "category": "design",
  "icon": "",
  "description": "Insert an icon from your icon libraries.",
  "supports": {
    "html": false,
    "align": true,
    "anchor": true,
    "spacing": {
      "padding": true,
      "margin": true
    },
    "__experimentalBorder": {
      "color": true,
      "radius": true,
      "style": true,
      "width": true
    }
  },
  "attributes": {
    "svgContent": {
      "type": "string",
      "default": ""
    },
    "iconId": {
      "type": "number",
      "default": 0
    },
    "iconName": {
      "type": "string",
      "default": ""
    },
    "iconFilename": {
      "type": "string",
      "default": ""
    },
    "librarySlug": {
      "type": "string",
      "default": ""
    },
    "libraryDir": {
      "type": "string",
      "default": ""
    },
    "width": {
      "type": "string",
      "default": "48px"
    },
    "height": {
      "type": "string",
      "default": ""
    },
    "strokeWidth": {
      "type": "number",
      "default": 1.5
    },
    "iconColor": {
      "type": "string",
      "default": ""
    },
    "customIconColor": {
      "type": "string",
      "default": ""
    },
    "iconBackgroundColor": {
      "type": "string",
      "default": ""
    },
    "customIconBackgroundColor": {
      "type": "string",
      "default": ""
    },
    "gradient": {
      "type": "string",
      "default": ""
    },
    "customGradient": {
      "type": "string",
      "default": ""
    },
    "iconWidth": {
      "type": "number",
      "default": 24
    },
    "iconHeight": {
      "type": "number",
      "default": 24
    },
    "rotate": {
      "type": "number",
      "default": 0
    },
    "flipHorizontal": {
      "type": "boolean",
      "default": false
    },
    "flipVertical": {
      "type": "boolean",
      "default": false
    },
    "linkUrl": {
      "type": "string",
      "default": ""
    },
    "linkTarget": {
      "type": "string",
      "default": ""
    },
    "linkRel": {
      "type": "string",
      "default": ""
    },
    "label": {
      "type": "string",
      "default": ""
    },
    "title": {
      "type": "string",
      "default": ""
    },
    "itemsJustification": {
      "type": "string",
      "default": ""
    },
    "hoverEffect": {
      "type": "string",
      "default": "none"
    }
  },
  "textdomain": "icon-base",
  "editorScript": "file:./index.js",
  "editorStyle": "file:./editor.css",
  "style": "file:./style-index.css"
}
